{
    "name": "d-manifold",
    "description": "D bindings for elalish/manifold — robust mesh boolean operations (CSG) via the official manifoldc C API. Static linking.",
    "license": "Apache-2.0",
    "authors": ["Alexander Shagarov"],

    "sourcePaths": ["source"],
    "importPaths": ["source"],

    "preBuildCommands-posix": [
        "cd \"$PACKAGE_DIR\" && git submodule update --init --recursive --quiet",
        "cmake -S \"$PACKAGE_DIR\" -B \"$PACKAGE_DIR/build\" -DCMAKE_BUILD_TYPE=Release",
        "cmake --build \"$PACKAGE_DIR/build\" -j --target manifoldc"
    ],
    "preBuildCommands-windows": [
        "git -C \"$PACKAGE_DIR\" submodule update --init --recursive",
        "cmake -S \"$PACKAGE_DIR\" -B \"$PACKAGE_DIR/build\"",
        "cmake --build \"$PACKAGE_DIR/build\" --config Release --target manifoldc"
    ],

    "lflags-linux": [
        "-L$PACKAGE_DIR/build/extern/manifold/bindings/c",
        "-L$PACKAGE_DIR/build/extern/manifold/src",
        "-L$PACKAGE_DIR/build/_deps/clipper2-build",
        "--start-group",
        "-lmanifoldc",
        "-lmanifold",
        "-lClipper2",
        "--end-group",
        "-lstdc++",
        "-lm"
    ],
    "lflags-osx": [
        "-L$PACKAGE_DIR/build/extern/manifold/bindings/c",
        "-L$PACKAGE_DIR/build/extern/manifold/src",
        "-L$PACKAGE_DIR/build/_deps/clipper2-build",
        "-lmanifoldc",
        "-lmanifold",
        "-lClipper2",
        "-lc++",
        "-lm"
    ],
    "lflags-windows": [
        "$PACKAGE_DIR/build/extern/manifold/bindings/c/Release/manifoldc.lib",
        "$PACKAGE_DIR/build/extern/manifold/src/Release/manifold.lib",
        "$PACKAGE_DIR/build/_deps/clipper2-build/Release/Clipper2.lib"
    ],
    "dflags-windows": ["-mscrtlib=msvcrt"],

    "configurations": [
        {
            "name": "library",
            "targetType": "staticLibrary"
        },
        {
            "name": "boolean",
            "targetType": "executable",
            "targetName": "boolean",
            "mainSourceFile": "examples/boolean.d"
        }
    ]
}
